rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSelf(uid);

      match /follows/{followedUid} {
        allow read, delete: if isSelf(uid);
        // Blocked-from-following check: reject if followedUid has blocked
        // uid. Covers both a brand-new follow and re-following after an
        // unfollow (followUser() unconditionally setDoc()s, which hits
        // `update` rather than `create` if the doc still exists from a
        // prior follow — same check either way).
        allow create, update: if isSelf(uid) &&
          !exists(/databases/$(database)/documents/users/$(followedUid)/blocks/$(uid));
      }

      // One-directional block — see src/utils/follows.js#blockUser. Only
      // the blocker can read/write their own block list; the *other*
      // direction of severing the relationship (removing the blocker from
      // the blocked user's own following list) is Cloud-Functions-only
      // (onBlocked trigger), since a client can't write someone else's
      // follows subcollection.
      match /blocks/{blockedUid} {
        allow read, write: if isSelf(uid);
      }

      // Site activity feed (new follower, game won/lost/started, player
      // joined your room, game invite) — only ever created by Cloud
      // Functions (Admin SDK, bypasses rules entirely). The owner can
      // delete their own entries though — e.g. dismissing a responded-to
      // invite (Join/Decline) or clearing an old notification.
      match /activity/{eventId} {
        allow read: if isSelf(uid);
        allow create, update: if false;
        allow delete: if isSelf(uid);
      }
    }

    // Read-only from clients — seeded via scripts/seedCatalog.mjs (Admin SDK).
    match /gameCatalog/{gameType} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /roomCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      // Only freed when its room is being deleted by its host (see
      // gameRooms delete rule below) — read the room doc (still present;
      // deleteRoom() frees the code before deleting the room) to check.
      allow delete: if isSignedIn() &&
        get(/databases/$(database)/documents/gameRooms/$(resource.data.roomId)).data.hostUid == request.auth.uid &&
        get(/databases/$(database)/documents/gameRooms/$(resource.data.roomId)).data.status != 'active';
    }

    match /gameRooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostUid == request.auth.uid;
      // Covers both existing players updating the room (leave/start/end) and a
      // new joiner adding themselves to playerUids (they aren't in the old
      // doc yet, so check the *incoming* array too).
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.playerUids ||
        request.auth.uid in request.resource.data.playerUids
      );
      // Host-only cleanup for a room that isn't actively being played — an
      // active game must be ended (status -> completed) via "End Game
      // Early" first, so deleting never yanks a live game out from under
      // other players.
      allow delete: if isSignedIn() &&
        resource.data.hostUid == request.auth.uid &&
        resource.data.status != 'active';

      // Phase 1 (real Love Letter gameplay) territory — not written by this
      // build, but locked down now so hidden information never leaks.
      match /state/{document=**} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/gameRooms/$(roomId)).data.playerUids;
        allow write: if false;
      }

      match /hands/{uid} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /log/{entryId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/gameRooms/$(roomId)).data.playerUids;
        allow write: if false;
      }

      // Holds the actual shuffled draw pile order — unlike state/**, this is
      // never readable by clients (even players in the room), since knowing
      // it would reveal everyone's future draws. Only Cloud Functions (Admin
      // SDK, which bypasses rules entirely) ever touch it. This block is
      // technically redundant with Firestore's default-deny for unmatched
      // paths, but written explicitly so the intent isn't implicit.
      match /secret/{document=**} {
        allow read, write: if false;
      }
    }
  }
}
